generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String
  school    Int
  schedule  Schedule[]
  createdAt DateTime   @default(now())

  @@unique([name, school])
}

model Schedule {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  period  Int
  subject String

  @@unique([userId, period])
}
